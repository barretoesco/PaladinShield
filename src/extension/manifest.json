{
  "manifest_version": 3,
  "name": "PaladinShield",
  "version": "0.1.3",
  "description": "PaladinShield — Runtime Enforcement Layer (REL) para Solana: cumplimiento en el motor del navegador antes de que exista la firma. Forense verificable, default-deny, signMessage y transacciones bajo la misma política. Roadmap: RPC Guard y Paladin Verified.",
  "permissions": ["storage", "tabs", "windows", "scripting"],
  "host_permissions": ["<all_urls>", "https://api.openai.com/*"],
  "background": {
    "service_worker": "scripts/background.js",
    "type": "module"
  },
  "action": {
    "default_title": "PaladinShield",
    "default_popup": "ui/popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["scripts/content_script.js"],
      "run_at": "document_start",
      "all_frames": true,
      "match_about_blank": true
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["scripts/inject.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
